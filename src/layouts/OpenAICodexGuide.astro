---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={frontmatter.title} description={frontmatter.description} />
    <style is:global>
      .post-hero {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #e5e7eb;
      }
      .post-hero h1 {
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -.03em;
        line-height: 1.2;
        margin-bottom: .4rem;
      }
      .post-hero .lead {
        font-size: 1rem;
        color: #6b7280;
        line-height: 1.6;
      }

      .toc {
        margin-bottom: 3rem;
      }
      .toc-title {
        font-size: .7rem;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #9ca3af;
        font-weight: 600;
        margin-bottom: .8rem;
      }
      .toc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: .5rem;
      }
      .toc-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem .7rem;
        border: 1px solid #f3f4f6;
        border-radius: 6px;
        font-size: .82rem;
        color: #374151;
        text-decoration: none;
        transition: border-color .15s, background .15s;
      }
      .toc-item:hover {
        border-color: #d1d5db;
        background: #fafafa;
      }
      .toc-num {
        font-size: .7rem;
        font-weight: 700;
        color: #9ca3af;
        min-width: 1.2rem;
      }

      .section-tag {
        display: inline-block;
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #9ca3af;
        font-weight: 600;
        margin: 3rem 0 .6rem;
        padding-bottom: .3rem;
        border-bottom: 2px solid #111;
      }

      .case {
        margin: 1.8rem 0;
      }
      .case-head {
        display: flex;
        align-items: baseline;
        gap: .5rem;
        margin-bottom: .8rem;
      }
      .case-id {
        font-size: .7rem;
        font-weight: 700;
        color: #9ca3af;
      }
      .case-title {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -.01em;
      }
      .case-body {
        font-size: .9rem;
        line-height: 1.8;
        color: #374151;
        margin-bottom: 1rem;
      }

      .prompt-group {
        margin: .8rem 0;
      }
      .prompt-label {
        font-size: .7rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #9ca3af;
        font-weight: 600;
        margin-bottom: .4rem;
      }
      .prompt-item {
        position: relative;
        background: #fafafa;
        border-left: 2px solid #d1d5db;
        padding: .4rem .8rem;
        margin-bottom: .35rem;
        font-size: .82rem;
        color: #374151;
        line-height: 1.6;
        border-radius: 0 4px 4px 0;
      }

      .insight {
        margin: 1rem 0;
        padding: .6rem 0;
        border-top: 1px solid #f3f4f6;
      }
      .insight-quote {
        font-size: .85rem;
        color: #4b5563;
        font-style: italic;
        line-height: 1.7;
      }
      .insight-author {
        font-size: .72rem;
        color: #9ca3af;
        font-style: normal;
        margin-top: .3rem;
      }

      .tip-list {
        margin: 1.5rem 0;
      }
      .tip-item {
        display: flex;
        gap: .6rem;
        margin-bottom: .8rem;
      }
      .tip-key {
        flex-shrink: 0;
        min-width: 6rem;
        font-size: .78rem;
        font-weight: 600;
        color: #6b7280;
        padding-top: .1rem;
      }
      .tip-val {
        font-size: .85rem;
        color: #374151;
        line-height: 1.7;
      }

      .post-meta-footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
        font-size: .75rem;
        color: #9ca3af;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .post-meta-footer a { color: #2563eb; text-decoration: none; }
      .post-meta-footer a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
