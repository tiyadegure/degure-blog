---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={frontmatter.title} description={frontmatter.description} />
    <script>
      window.MathJax = {
        tex: { inlineMath: [['\\(', '\\)']], displayMath: [['\\[', '\\]']] },
        svg: { fontCache: 'global' }
      };
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
    <style is:global>
      .risk-hero {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #e5e7eb;
      }
      .risk-hero h1 {
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -.03em;
        line-height: 1.2;
        margin-bottom: .4rem;
      }
      .risk-hero .lead {
        font-size: 1rem;
        color: #6b7280;
        line-height: 1.6;
      }

      .risk-section {
        margin: 2rem 0;
        padding: 1.5rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
      }
      .risk-section h2 {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #111;
      }
      .risk-section h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 1.2rem 0 .6rem;
        color: #374151;
      }
      .risk-section p {
        font-size: .9rem;
        line-height: 1.8;
        color: #374151;
        margin-bottom: .8rem;
      }

      .formula-box {
        margin: 1rem 0;
        padding: 1rem 1.2rem;
        border-left: 3px solid #2563eb;
        border-radius: 0 6px 6px 0;
        background: #f8fafc;
        overflow-x: auto;
      }

      .case-box {
        margin: 1rem 0;
        padding: 1rem 1.2rem;
        border: 1px solid #fbbf24;
        border-radius: 6px;
        background: #fffbeb;
      }
      .case-box strong {
        display: block;
        margin-bottom: .4rem;
        color: #92400e;
      }

      .check-box {
        margin: 1rem 0;
        padding: 1rem 1.2rem;
        border: 1px solid #34d399;
        border-radius: 6px;
        background: #ecfdf5;
        font-size: .85rem;
        color: #065f46;
      }

      .symbol-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: .85rem;
      }
      .symbol-table th,
      .symbol-table td {
        border: 1px solid #e5e7eb;
        padding: .6rem .8rem;
        text-align: left;
      }
      .symbol-table th {
        background: #f8fafc;
        font-weight: 600;
        color: #374151;
      }
      .symbol-table td {
        color: #4b5563;
      }

      .homework-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: .85rem;
      }
      .homework-table th,
      .homework-table td {
        border: 1px solid #e5e7eb;
        padding: .6rem .8rem;
        vertical-align: top;
      }
      .homework-table th {
        background: #f8fafc;
        font-weight: 600;
        color: #374151;
      }
      .homework-table td {
        color: #4b5563;
        line-height: 1.6;
      }

      .risk-nav {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: .5rem;
        margin: 2rem 0;
      }
      .risk-nav a {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem .7rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: .82rem;
        color: #374151;
        text-decoration: none;
        transition: border-color .15s, background .15s;
      }
      .risk-nav a:hover {
        border-color: #d1d5db;
        background: #fafafa;
      }

      .post-meta-footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
        font-size: .75rem;
        color: #9ca3af;
      }
      .post-meta-footer a { color: #2563eb; text-decoration: none; }
      .post-meta-footer a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
