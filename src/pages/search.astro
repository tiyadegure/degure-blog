---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Search — Degure" description="Search all posts" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <h1 class="text-2xl font-semibold mb-8">Search</h1>
      <div id="search" class="mb-8"></div>
      <div id="results"></div>

      <script is:inline>
        window.addEventListener('DOMContentLoaded', async () => {
          const pagefind = await import('/pagefind/pagefind.js');
          await pagefind.init();

          const searchEl = document.getElementById('search');
          const resultsEl = document.getElementById('results');

          searchEl.innerHTML = `
            <input
              type="text"
              id="search-input"
              placeholder="Type to search…"
              class="w-full px-4 py-3 border border-neutral-200 rounded-lg bg-white text-neutral-900 focus:outline-none focus:border-neutral-400 transition-colors"
            />
          `;

          const input = document.getElementById('search-input');

          input.addEventListener('input', async (e) => {
            const query = e.target.value.trim();
            if (!query) {
              resultsEl.innerHTML = '';
              return;
            }

            const results = await pagefind.search(query);
            const data = await Promise.all(results.results.map(r => r.data()));

            if (data.length === 0) {
              resultsEl.innerHTML = `<p class="text-neutral-500">No results found.</p>`;
              return;
            }

            resultsEl.innerHTML = data.map(r => `
              <a href="${r.url}" class="block py-4 border-b border-neutral-100 hover:bg-neutral-50 transition-colors no-underline">
                <h2 class="text-lg font-medium text-neutral-900">${r.meta?.title || r.url}</h2>
                ${r.meta?.description ? `<p class="text-sm text-neutral-500 mt-1">${r.meta.description}</p>` : ''}
                <p class="text-sm text-neutral-400 mt-1 line-clamp-2">${r.excerpt}</p>
              </a>
            `).join('');
          });

          input.focus();
        });
      </script>
    </main>
    <Footer />
  </body>
</html>
