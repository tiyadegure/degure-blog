---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{SITE_TITLE}</h1>
      <p class="text-gray-500 mb-10">{SITE_DESCRIPTION}</p>

      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Recent Posts</h2>
      <ul class="space-y-6">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="block group">
              <p class="text-gray-400 text-sm mb-1">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <p class="text-gray-900 font-medium group-hover:text-blue-600 transition-colors">
                {post.data.title}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
