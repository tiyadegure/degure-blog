---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description="All blog posts" />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="text-2xl font-bold text-gray-900 mb-8">Blog</h1>
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="block group">
              <p class="text-gray-400 text-sm mb-1">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <p class="text-lg text-gray-900 font-medium group-hover:text-blue-600 transition-colors">
                {post.data.title}
              </p>
              {post.data.description && (
                <p class="text-gray-500 text-sm mt-1">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
